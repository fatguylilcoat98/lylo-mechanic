{
  "expo": {
    "name": "LYLO Mechanic",
    "slug": "lylo-mechanic",
    "version": "0.2.0",
    "orientation": "portrait",
    "icon": "./assets/lylo_mechanic_logo_.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/lylo_mechanic_logo_.png",
      "resizeMode": "contain",
      "backgroundColor": "#070b14"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/lylo_mechanic_logo_.png",
        "backgroundColor": "#070b14"
      },
      "package": "com.goodneighborguard.lylomechanic",
      "permissions": [
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.BLUETOOTH_SCAN",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.goodneighborguard.lylomechanic",
      "infoPlist": {
        "NSBluetoothAlwaysUsageDescription": "LYLO Mechanic needs Bluetooth to connect to your OBDLink adapter.",
        "NSBluetoothPeripheralUsageDescription": "LYLO Mechanic needs Bluetooth to connect to your OBDLink adapter."
      }
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 23,
            "compileSdkVersion": 34,
            "targetSdkVersion": 34,
            "kotlinVersion": "1.9.24"
          }
        }
      ],
      [
        "react-native-ble-plx",
        {
          "isBackgroundEnabled": false,
          "modes": ["central"],
          "bluetoothAlwaysPermission": "LYLO Mechanic needs Bluetooth to connect to your OBDLink adapter.",
          "neverForLocation": true
        }
      ],
      "./plugins/withBluetoothClassic"
    ],
    "extra": {
      "eas": {
        "projectId": "916eda9d-5bf2-40c4-abdb-22ea6e491d96"
      }
    },
    "owner": "stangman1998"
  }
}
